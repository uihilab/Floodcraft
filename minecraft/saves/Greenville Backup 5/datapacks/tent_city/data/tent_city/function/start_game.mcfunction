function tent_city:reset
scoreboard players set #state tent_state 1
gamemode adventure @a
title @a title {"text":"TENT CITY RESCUE","bold":true,"color":"gold"}
title @a subtitle {"text":"Rescue the 4 stranded citizens!","color":"yellow"}

# Place sign above button (using replace to override existing blocks)
setblock 540 -41 345 minecraft:oak_wall_sign[facing=east]{front_text:{messages:['{"text":"Tent City","bold":true,"color":"dark_red"}','{"text":"Rescue Mission","color":"dark_blue"}','{"text":""}','{"text":"Press Button","color":"dark_green"}']}} replace

# Give objective book with correct 1.20 NBT format (using direct § section symbol)
give @a minecraft:written_book[minecraft:written_book_content={title:"Rescue Guide",author:"Directions",pages:['{"text":"§6§lTent City Rescue\\n\\n§0Four citizens are stranded in the floodwater.\\n\\nRight-click the boat to get in! Row out and rescue them.\\n\\nThey will board automatically."}','{"text":"§6§lDropping Off\\n\\n§0Row back to the tents on the levee.\\n\\nWhen you get close to any of the 4 tents, they will be dropped off.\\n\\nRescue all 4 to win!"}']}] 1

# start.mcfunction - Phase 1: Containment Test & Phase 2: Flood
give @a minecraft:spruce_boat 1
tellraw @a ["",{"text":"[Tent City] ","color":"gold"},{"text":"Generating containment field...","color":"green"}]
